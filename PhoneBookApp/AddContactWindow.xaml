<Window x:Class="PhoneBookApp.AddContactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Add contact" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Height="315" 
        Width="300">
    <Window.Resources>
        <Style TargetType="{x:Type TextBox}" 
               BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
        
        <Style
            TargetType="{x:Type TextBlock}"
            BasedOn="{StaticResource MaterialDesignTextBlock}">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="Visibility" Value="Hidden"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="70" />
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0"
                Background="#F7F7F7"
                Padding="15">
            <StackPanel>
                <TextBox x:Name="NameInput"
                         materialDesign:HintAssist.Hint="Name"/>
                <TextBlock x:Name="NameErrorText"
                           Text="Name cannot be empty"/>

                <TextBox x:Name="NumberInput"
                         materialDesign:HintAssist.Hint="Number"/>
                <TextBlock x:Name="NumberErrorText"
                           Text="Number cannot be empty"/>

                <TextBox x:Name="EmailInput"
                         materialDesign:HintAssist.Hint="E-mail"/>
                <TextBlock x:Name="EmailErrorText"
                           Text="Invalid email address"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1"
                Background="#f6f5f7"
                BorderBrush="#C8C8C8"
                BorderThickness="1,1,0,0"
                Padding="15">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button x:Name="AddButton" 
                        Content="Add" 
                        Style="{StaticResource AddButton}"
                        Click="AddButton_Click"/>
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Style="{StaticResource NormalButton}"
                        IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>