<Application x:Class="PhoneBookApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme 
                    BaseTheme="Light"
                    PrimaryColor="#3875c5"
                    SecondaryColor="#E3E1E4"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <Style x:Key="AddButton"
                   TargetType="{x:Type Button}" 
                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="#3875C5"/>
                <Setter Property="BorderBrush" Value="#3875C5"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Width" Value="80"/>
                <Setter Property="Padding" Value="6,4,6,4"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
            </Style>
            
            <Style x:Key="NormalButton"
                   TargetType="{x:Type Button}" 
                   BasedOn="{StaticResource AddButton}">
                <Setter Property="Background" Value="#E3E1E4"/>
                <Setter Property="BorderBrush" Value="#E3E1E4"/>
                <Setter Property="Foreground" Value="Black"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>